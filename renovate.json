{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "packageRules": [
    {
      "groupName": "{{manager}} non-major dependencies",
      "groupSlug": "{{manager}}-minor-patch",
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["*"],
      "excludeDepNames": ["ruby", "node", "mozjpeg", "vips", "ffmpeg", "exiftool"]
    },
    {
      "groupName": "ruby version",
      "groupSlug": "ruby-version",
      "matchDepNames": ["ruby"],
      "matchFileNames": [".tool-versions", ".ruby-version", "Dockerfile", "Gemfile"]
    },
    {
      "groupName": "node version",
      "groupSlug": "node-version",
      "matchDepNames": ["node"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "mozjpeg",
      "groupSlug": "mozjpeg",
      "matchDepNames": ["mozjpeg"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "libvips",
      "groupSlug": "libvips",
      "matchDepNames": ["vips"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "ffmpeg",
      "groupSlug": "ffmpeg",
      "matchDepNames": ["ffmpeg"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "exiftool",
      "groupSlug": "exiftool",
      "matchDepNames": ["exiftool"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "dtext dockerfile",
      "groupSlug": "dtext-dockerfile",
      "matchFileNames": ["lib/dtext_rb/Dockerfile"]
    }
  ]
}
