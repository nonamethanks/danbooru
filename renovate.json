{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "minimumReleaseAge": "14 days",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG RUBY_VERSION=\"(?<currentValue>[\\d.]+)\""],
      "depNameTemplate": "ruby",
      "datasourceTemplate": "ruby-version"
    }
  ],
  "packageRules": [
    {
      "groupName": "{{manager}} non-major dependencies",
      "groupSlug": "{{manager}}-minor-patch",
      "matchManagers": [
        "npm",
        "bundler"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "commitMessageTopic": "{{manager}} dependency {{depName}}",
      "matchManagers": [
        "npm",
        "bundler"
      ],
      "matchUpdateTypes": [
        "major"
      ]
    },
    {
      "groupName": "Ruby version",
      "matchDepNames": ["ruby"],
      "matchFileNames": ["Dockerfile", ".ruby-version", "Gemfile", "Gemfile.lock"]
    }
  ]
}
