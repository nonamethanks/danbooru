{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "{{manager}} non-major dependencies",
      "groupSlug": "{{manager}}-minor-patch",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "groupName": "ruby version",
      "groupSlug": "ruby-version",
      "matchPackageNames": ["ruby"],
      "matchManagers": ["asdf", "ruby-version", "dockerfile"]
    },
    {
      "groupName": "node version",
      "groupSlug": "node-version",
      "matchPackageNames": ["node"],
      "matchManagers": ["asdf", "dockerfile"]
    },
    {
      "groupName": "mozjpeg",
      "groupSlug": "mozjpeg",
      "matchPackageNames": ["mozjpeg"],
      "matchManagers": ["asdf", "dockerfile"]
    },
    {
      "groupName": "libvips",
      "groupSlug": "libvips",
      "matchPackageNames": ["vips"],
      "matchManagers": ["asdf", "dockerfile"]
    },
    {
      "groupName": "ffmpeg",
      "groupSlug": "ffmpeg",
      "matchPackageNames": ["ffmpeg"],
      "matchManagers": ["asdf", "dockerfile"]
    },
    {
      "groupName": "exiftool",
      "groupSlug": "exiftool",
      "matchPackageNames": ["exiftool"],
      "matchManagers": ["asdf", "dockerfile"]
    }
  ]
}
