{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/", "/^\\.tool-versions$/"],
      "matchStrings": ["ARG RUBY_VERSION=\"(?<currentValue>[^\"]+)\"", "ruby (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "ruby",
      "datasourceTemplate": "ruby-version",
      "packageNameTemplate": "ruby"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/", "/^\\.tool-versions$/"],
      "matchStrings": ["ARG NODE_VERSION=\"(?<currentValue>[^\"]+)\"", "node (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/", "/^\\.tool-versions$/"],
      "matchStrings": ["ARG MOZJPEG_VERSION=\"(?<currentValue>[^\"]+)\"", "mozjpeg (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "mozjpeg",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "mozilla/mozjpeg",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/", "/^\\.tool-versions$/"],
      "matchStrings": ["ARG VIPS_VERSION=\"(?<currentValue>[^\"]+)\"", "vips (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "vips",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "libvips/libvips",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/", "/^\\.tool-versions$/"],
      "matchStrings": ["ARG FFMPEG_VERSION=\"(?<currentValue>[^\"]+)\"", "ffmpeg (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "ffmpeg",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "FFmpeg/FFmpeg",
      "extractVersionTemplate": "^n(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/", "/^\\.tool-versions$/"],
      "matchStrings": ["ARG EXIFTOOL_VERSION=\"(?<currentValue>[^\"]+)\"", "exiftool (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "exiftool",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "exiftool/exiftool"
    }
  ],
  "packageRules": [
    {
      "groupName": "{{manager}} non-major dependencies",
      "groupSlug": "{{manager}}-minor-patch",
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["*"],
      "excludeDepNames": ["ruby", "node", "mozjpeg", "vips", "ffmpeg", "exiftool"]
    },
    {
      "groupName": "ruby version",
      "groupSlug": "ruby-version",
      "matchDepNames": ["ruby"],
      "matchFileNames": [".tool-versions", ".ruby-version", "Dockerfile", "Gemfile"]
    },
    {
      "groupName": "node version",
      "groupSlug": "node-version",
      "matchDepNames": ["node"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "mozjpeg",
      "groupSlug": "mozjpeg",
      "matchDepNames": ["mozjpeg"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "libvips",
      "groupSlug": "libvips",
      "matchDepNames": ["vips"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "ffmpeg",
      "groupSlug": "ffmpeg",
      "matchDepNames": ["ffmpeg"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "exiftool",
      "groupSlug": "exiftool",
      "matchDepNames": ["exiftool"],
      "matchFileNames": [".tool-versions", "Dockerfile"]
    },
    {
      "groupName": "dtext dockerfile",
      "groupSlug": "dtext-dockerfile",
      "matchFileNames": ["lib/dtext_rb/Dockerfile"]
    }
  ]
}
